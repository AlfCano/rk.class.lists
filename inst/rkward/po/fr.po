msgid "data"
msgstr "Données"

msgid "Class and Structure"
msgstr "Classe et Structure"

msgid "Manipulate Lists"
msgstr "Manipuler des Listes"

msgid "Coerce Data Structure"
msgstr "Convertir la Structure des Données"

msgid "Select Object"
msgstr "Sélectionner un Objet"

msgid "Target Structure"
msgstr "Structure Cible"

msgid "Vector (as.vector)"
msgstr "Vecteur (as.vector)"

msgid "Matrix (as.matrix)"
msgstr "Matrice (as.matrix)"

msgid "Data Frame (as.data.frame)"
msgstr "Data Frame (as.data.frame)"

msgid "List (as.list)"
msgstr "Liste (as.list)"

msgid "Save result as"
msgstr "Enregistrer le résultat sous"

msgid "Conversion Method"
msgstr "Méthode de Conversion"

msgid "Converts R objects between basic data structures: vector, matrix, data.frame, and list."
msgstr "Convertit les objets R entre les structures de données de base : vector, matrix, data.frame et list."

msgid "Select an object and choose the desired target structure."
msgstr "Sélectionnez un objet et choisissez la structure cible souhaitée."

msgid "The target R class/structure."
msgstr "La classe/structure R cible."

msgid "Coerce Vector Type"
msgstr "Convertir le Type de Vecteur"

msgid "Select Vector/Variable"
msgstr "Sélectionner Vecteur/Variable"

msgid "Target Data Type"
msgstr "Type de Données Cible"

msgid "Integer (as.integer)"
msgstr "Entier (as.integer)"

msgid "Numeric (as.numeric)"
msgstr "Numérique (as.numeric)"

msgid "Character (as.character)"
msgstr "Caractère (as.character)"

msgid "Factor (as.factor)"
msgstr "Facteur (as.factor)"

msgid "Logical (as.logical)"
msgstr "Logique (as.logical)"

msgid "NULL (as.null - creates empty)"
msgstr "NULL (as.null - crée un objet vide)"

msgid "Converts an object or vector to a specific atomic type (integer, numeric, factor, etc.)."
msgstr "Convertit un objet ou un vecteur vers un type atomique spécifique (entier, numérique, facteur, etc.)."

msgid "Select a variable and the target type."
msgstr "Sélectionnez une variable et le type cible."

msgid "The target atomic mode."
msgstr "Le mode atomique cible."

msgid "Batch Column Coercion"
msgstr "Conversion de Colonnes par Lot"

msgid "Target Data Frame"
msgstr "Data Frame Cible"

msgid "Vector containing Column Names"
msgstr "Vecteur contenant les Noms des Colonnes"

msgid "Convert Columns To"
msgstr "Convertir les Colonnes En"

msgid "Factor"
msgstr "Facteur"

msgid "Character"
msgstr "Caractère"

msgid "Numeric"
msgstr "Numérique"

msgid "Integer"
msgstr "Entier"

msgid "Logical"
msgstr "Logique"

msgid "Save Data Frame as"
msgstr "Enregistrer le Data Frame sous"

msgid "Data to Modify"
msgstr "Données à Modifier"

msgid "List/Vector of Column Names"
msgstr "Liste/Vecteur de Noms de Colonnes"

msgid "Target Type"
msgstr "Type Cible"

msgid "Converts a specific set of columns within a data frame to a single type, based on a vector of names."
msgstr "Convertit un ensemble spécifique de colonnes dans un data frame vers un seul type, en se basant sur un vecteur de noms."

msgid "Select the target dataframe and a vector containing the names of the columns to modify."
msgstr "Sélectionnez le data frame cible et un vecteur contenant les noms des colonnes à modifier."

msgid "The dataframe containing the data."
msgstr "Le data frame contenant les données."

msgid "A character vector with the names of the columns to convert."
msgstr "Un vecteur de caractères avec les noms des colonnes à convertir."

msgid "The target type for the selected columns."
msgstr "Le type cible pour les colonnes sélectionnées."

msgid "Create or Append List"
msgstr "Créer ou Ajouter à une Liste"

msgid "Mode"
msgstr "Mode"

msgid "Create New List"
msgstr "Créer une Nouvelle Liste"

msgid "Append to Existing List"
msgstr "Ajouter à une Liste Existante"

msgid "Existing List (for Append)"
msgstr "Liste Existante (pour Ajouter)"

msgid "Objects to Add/Combine"
msgstr "Objets à Ajouter/Combiner"

msgid "Remove original objects from Workspace after assignment"
msgstr "Supprimer les objets originaux de l'Espace de travail après l'affectation"

msgid "Save List as"
msgstr "Enregistrer la Liste sous"

msgid "Creates a new list from selected objects or appends objects to an existing list, using the object names as keys."
msgstr "Crée une nouvelle liste à partir d'objets sélectionnés ou ajoute des objets à une liste existante, en utilisant les noms des objets comme clés."

msgid "Select the objects to combine. If appending, select the base list."
msgstr "Sélectionnez les objets à combiner. Si vous ajoutez, sélectionnez la liste de base."

msgid "Choose whether to start a fresh list or add to an existing one."
msgstr "Choisissez de commencer une nouvelle liste ou d'ajouter à une liste existante."

msgid "The R objects to include. They will be assigned to the list using their names as the index."
msgstr "Les objets R à inclure. Ils seront assignés à la liste en utilisant leurs noms comme index."

msgid "If checked, top-level objects will be removed from the Global Environment after assignment."
msgstr "Si coché, les objets de niveau supérieur seront supprimés de l'Environnement Global après l'affectation."

msgid "Extract List Elements"
msgstr "Extraire des Éléments de Liste"

msgid "Select Elements to Extract"
msgstr "Sélectionner les Éléments à Extraire"

msgid "Save Extracted Object(s) as"
msgstr "Enregistrer le ou les Objets Extraits sous"

msgid "Extracts specific elements (vectors, sub-lists, etc.) from an existing list or dataframe."
msgstr "Extrait des éléments spécifiques (vecteurs, sous-listes, etc.) d'une liste ou d'un data frame existant."

msgid "Select specific elements. If one is selected, the object class is preserved. If multiple are selected, they are returned as a named list."
msgstr "Sélectionnez des éléments spécifiques. Si un seul est sélectionné, la classe de l'objet est préservée. Si plusieurs sont sélectionnés, ils sont retournés sous forme de liste nommée."

msgid "The objects/elements to extract."
msgstr "Les objets/éléments à extraire."